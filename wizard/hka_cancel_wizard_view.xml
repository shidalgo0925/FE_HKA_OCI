<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hka_cancel_wizard_form" model="ir.ui.view">
        <field name="name">hka.cancel.wizard.form</field>
        <field name="model">hka.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Anular en DGI">
                <sheet>
                    <group>
                        <field name="move_id"/>
                        <field name="motivo_anulacion" placeholder="Motivo de la anulación (opcional)"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirmar" class="btn-primary" type="object"/>
                    <button name="action_cancel" string="Cancelar" class="btn-secondary" type="object"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
